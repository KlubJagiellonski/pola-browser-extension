{
    "manifest_version": 3,

    "name": "Pola",

    "version": "0.2",

    "description": "Sprawdź, czy kupujesz polski produkt",

    "homepage_url": "https://www.pola-app.pl/",

    "author": "Klub Jagiellonski",

    "icons": {
        "128": "icons/pola-128.png",
        "64": "icons/pola-64.png",
        "32": "icons/pola-32.png"
    },

    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],

    "host_permissions": [
        "https://www.pola-app.pl/*"
    ],

    "action": {
        "default_icon": {
            "128": "icons/pola-128.png",
            "64": "icons/pola-64.png",
            "32": "icons/pola-32.png"
        },
        "default_title": "Pola",
        "default_popup": "popup/pola.html"
    },

    "content_scripts": [
        {
            "matches": ["https://*/*", "http://*/*"],
            "js": ["content_scripts/pola.js"],
            "run_at": "document_end"
        }
    ]
}